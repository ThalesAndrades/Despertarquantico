# ============================================================
# Despertar Espiral — Environment configuration
# ------------------------------------------------------------
# Copy this file to `.env` at the project root on the server.
# NEVER commit the real .env — it is git-ignored.
# Deploy via git: create the .env manually once on Hostinger,
# then `git pull` normally; configs read from here at runtime.
# ============================================================

# --- Application ---
APP_NAME="Despertar Espiral"
APP_URL=https://despertarespiral.com
APP_ENV=production
APP_DEBUG=false

# --- Database (Hostinger MySQL) ---
DB_HOST=localhost
DB_NAME=u525832347_Mulherespiral
DB_USER=u525832347_Mulherespiral
DB_PASS=
DB_CHARSET=utf8mb4

# --- Initial admin user (only used once on first migrate) ---
# If ADMIN_INIT_PASSWORD is empty, no admin is auto-created — you must
# create one via install.php or by seeding the database manually.
ADMIN_INIT_EMAIL=sunyan@despertarespiral.com
ADMIN_INIT_PASSWORD=

# --- Mail (transactional fallback: reset password, order receipt) ---
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_SECURE=ssl
MAIL_USER=noreply@despertarespiral.com
MAIL_PASS=
MAIL_FROM_EMAIL=noreply@despertarespiral.com
MAIL_FROM_NAME="Despertar Espiral"

# --- Asaas payment gateway (BR: PIX + cartão + boleto) ---
# API key from https://www.asaas.com/config/integrations
ASAAS_API_KEY=
# sandbox | production
ASAAS_ENV=sandbox
# Pre-shared token used to authenticate webhook calls.
# Paste the same value in Asaas dashboard when creating the webhook.
ASAAS_WEBHOOK_TOKEN=
# Optional: wallet id for future split payments
ASAAS_WALLET_ID=

# --- Sequenzy lifecycle automation ---
# Workspace webhook URL from Sequenzy dashboard
SEQUENZY_WEBHOOK_URL=
SEQUENZY_ENABLED=true
SEQUENZY_TIMEOUT=3
